{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/Rome",
  "branchPrefix": "renovate/",
  "prConcurrentLimit": 5,
  "automergeStrategy": "squash",
  "separateMajorMinor": true,
  "flux": {
    "fileMatch": [
      "(^|/)apps/.+\\.ya?ml$",
      "(^|/)infrastructure/.+\\.ya?ml$",
      "(^|/)clusters/.+\\.ya?ml$"
    ]
  },
  "regexManagers": [
    {
      "description": "Docker images with repository + tag on separate lines in HelmRelease values",
      "fileMatch": [
        "(^|/)apps/.*helm-release\\.ya?ml$",
        "(^|/)infrastructure/.*helm-release\\.ya?ml$"
      ],
      "matchStrings": [
        "repository:\\s*['\"]?(?<depName>[^'\"\\s]+)['\"]?\\s*\\n(?:[^\\n]*\\n){0,3}?\\s*tag:\\s*['\"]?(?<currentValue>[^'\"\\s@]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "{{{depName}}}"
    }
  ],
  "packageRules": [
    {
      "description": "Global: group minor+patch Helm updates per chart",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "helm {{depName}}",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["automerge", "helm"]
    },
    {
      "description": "Global: major Helm updates require review",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["needs-review", "helm"]
    },
    {
      "description": "Docker: minor+patch automerge",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["automerge", "docker"]
    },
    {
      "description": "Docker: major requires review",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["needs-review", "docker"]
    },
    {
      "description": "Immich: always manual review (breaking changes on minor)",
      "matchPackageNames": [
        "immich",
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning",
        "docker.io/valkey/valkey"
      ],
      "automerge": false,
      "labels": ["needs-review"]
    },
    {
      "description": "kube-prometheus-stack: only patch automerge (minor can break CRDs)",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["needs-review", "helm"]
    },
    {
      "description": "Authentik: only patch automerge (minor may require migrations)",
      "matchPackageNames": ["authentik", "ghcr.io/goauthentik/server"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["needs-review"]
    },
    {
      "description": "GitHub Actions: pin digests and automerge minor/patch",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["automerge", "ci"]
    },
    {
      "description": "GitHub Actions: major requires review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["needs-review", "ci"]
    }
  ]
}
